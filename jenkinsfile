pipeline {
    agent any

    triggers {
        githubPush()
    }

    tools {
        "dependency-check" 'dependency-check'
    }

    stages {

        stage('1. Workspace Init') {
            steps {
                sh """
                    rm -rf ${WORKSPACE}/src ${WORKSPACE}/output
                    mkdir -p ${WORKSPACE}/src ${WORKSPACE}/output
                """
            }
        }

        stage('2. Source Code Checkout') {
            steps {
                dir("${WORKSPACE}/src") {
                    git url: 'https://github.com/juice-shop/juice-shop.git', branch: 'master'
                    sh 'ls -la'
                }
            }
        }

        stage('3. Dependency Install') {
            steps {
                dir("${WORKSPACE}/src") {
                    script {
                        docker.image('node:20').inside('--user root') {
                            sh """
                                node --version && npm --version
                                npm install --legacy-peer-deps
                                npm install --package-lock-only --legacy-peer-deps --ignore-scripts
                                cd frontend && npm install --package-lock-only --legacy-peer-deps --ignore-scripts && cd ..
                                npm audit --json > ${WORKSPACE}/output/npm-audit-root.json 2>/dev/null || true
                                cd frontend && npm audit --json > ${WORKSPACE}/output/npm-audit-frontend.json 2>/dev/null || true
                            """
                        }
                    }
                }
            }
        }

        stage('4. Semgrep SAST Scan') {
            steps {
                dir("${WORKSPACE}/src") {
                    script {
                        docker.image('returntocorp/semgrep:latest').inside('--user root') {
                            sh """
                                semgrep --config=auto --json \\
                                    --output=${WORKSPACE}/output/semgrep-result.json \\
                                    . || true
                            """
                        }
                    }
                }
            }
        }

        stage('5. Trivy SCA Scan') {
            steps {
                dir("${WORKSPACE}/src") {
                    script {
                        docker.image('aquasec/trivy:latest').inside('--user root --entrypoint= -v /tmp/trivy-cache:/root/.cache') {
                            sh """
                                trivy fs --scanners vuln --pkg-types library --format json \\
                                    --output ${WORKSPACE}/output/trivy-result.json \\
                                    --severity HIGH,CRITICAL --include-dev-deps --skip-dirs frontend . || true

                                trivy fs --scanners vuln --pkg-types library --format json \\
                                    --output ${WORKSPACE}/output/trivy-frontend-result.json \\
                                    --severity HIGH,CRITICAL --include-dev-deps ./frontend || true

                                trivy fs --scanners vuln --pkg-types library --format json \\
                                    --output ${WORKSPACE}/output/trivy-nodemodules-result.json \\
                                    --severity HIGH,CRITICAL ${WORKSPACE}/src/node_modules || true

                                if [ -f ${WORKSPACE}/src/frontend/dist/bom/bom.json ]; then
                                    trivy sbom --format json \\
                                        --output ${WORKSPACE}/output/trivy-sbom-result.json \\
                                        --severity HIGH,CRITICAL \\
                                        ${WORKSPACE}/src/frontend/dist/bom/bom.json || true
                                fi
                            """
                        }
                    }
                }
            }
        }

        stage('6. OWASP Dependency Check') {
            steps {
                dir("${WORKSPACE}/src") {
                    catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                        withCredentials([string(credentialsId: 'NVD_API_KEY', variable: 'NVD_KEY')]) {
                            dependencyCheck(
                                odcInstallation: 'dependency-check',
                                additionalArguments: '--nvdApiKey $NVD_KEY --format JSON --format HTML --format XML --out $WORKSPACE/output --scan . --disableYarnAudit --disableOssIndex --data /var/jenkins_home/owasp-data'
                            )
                        }
                    }
                }
            }
        }

        stage('6.5. CVE Merge & Dedup') {
            steps {
                script {
                    def anyTrivy = fileExists("${WORKSPACE}/output/trivy-result.json") ||
                                   fileExists("${WORKSPACE}/output/trivy-frontend-result.json")
                    if (!anyTrivy) {
                        echo "Trivy result missing - skip CVE merge"
                        return
                    }

                    writeFile file: "${WORKSPACE}/output/merge_vulns.py", text: '''
import json, xml.etree.ElementTree as ET, os, re
from collections import Counter

WS = os.environ["WORKSPACE"]
TRIVY_FILES = [
    WS + "/output/trivy-result.json",
    WS + "/output/trivy-frontend-result.json",
    WS + "/output/trivy-nodemodules-result.json",
    WS + "/output/trivy-sbom-result.json",
]
OWASP_FILE  = WS + "/output/dependency-check-report.xml"
NPM_FILES   = [WS + "/output/npm-audit-root.json", WS + "/output/npm-audit-frontend.json"]
OUTPUT_FILE = WS + "/output/merged_vulns.json"

SEV_MAP = {"critical":"CRITICAL","high":"HIGH","moderate":"MEDIUM","medium":"MEDIUM","low":"LOW","info":"INFO"}

def norm_sev(s):
    return SEV_MAP.get((s or "").lower(), "UNKNOWN")

def parse_trivy(paths):
    vulns = {}
    for path in paths:
        if not os.path.exists(path):
            continue
        with open(path, encoding="utf-8", errors="replace") as f:
            data = json.load(f)
        for result in data.get("Results", []):
            for v in result.get("Vulnerabilities") or []:
                vid = v.get("VulnerabilityID")
                if not vid:
                    continue
                cvss = None
                for src in (v.get("CVSS") or {}).values():
                    val = float(src.get("V3Score") or src.get("V2Score") or 0)
                    if val > 0:
                        cvss = max(cvss, val) if cvss is not None else val
                prev = vulns.get(vid)
                if prev is None or (cvss is not None and (prev["cvss"] is None or cvss > prev["cvss"])):
                    vulns[vid] = {"vuln_id":vid,"package":v.get("PkgName",""),"version":v.get("InstalledVersion",""),"severity":v.get("Severity","UNKNOWN"),"cvss":cvss,"source":"trivy"}
    print("[Trivy] " + str(len(vulns)) + " entries")
    return vulns

def parse_owasp(path):
    vulns = {}
    if not os.path.exists(path):
        return vulns
    tree = ET.parse(path)
    root = tree.getroot()
    ns  = root.tag.split("}")[0].strip("{") if "}" in root.tag else ""
    tag = lambda t: ("{" + ns + "}" + t) if ns else t
    for dep in root.iter(tag("dependency")):
        raw = dep.findtext(tag("fileName")) or ""
        pkg = re.sub(r"\\.(tgz|jar|zip|tar\\.gz|war|ear)$", "", raw)
        pkg = re.sub(r"-[\\d]+\\.[\\d].*$", "", pkg).lower().strip()
        for vuln in dep.iter(tag("vulnerability")):
            vid = vuln.findtext(tag("name")) or ""
            if not (vid.startswith("CVE-") or vid.startswith("GHSA-")):
                continue
            try:
                raw_cvss = float(vuln.findtext(tag("cvssV3")) or vuln.findtext(tag("cvssScore")) or 0)
                cvss = raw_cvss if raw_cvss > 0 else None
            except ValueError:
                cvss = None
            sev = norm_sev(vuln.findtext(tag("severity")) or "")
            prev = vulns.get(vid)
            if prev is None or (cvss is not None and (prev["cvss"] is None or cvss > prev["cvss"])):
                vulns[vid] = {"vuln_id":vid,"package":pkg,"version":"","severity":sev,"cvss":cvss,"source":"owasp"}
    print("[OWASP] " + str(len(vulns)) + " entries")
    return vulns

def parse_npm(paths):
    vulns = {}
    for path in paths:
        if not os.path.exists(path):
            continue
        with open(path, encoding="utf-8", errors="replace") as f:
            try:
                data = json.load(f)
            except json.JSONDecodeError:
                continue
        for pkg_name, info in (data.get("vulnerabilities") or {}).items():
            sev = norm_sev(info.get("severity", ""))
            for via in (info.get("via") or []):
                if not isinstance(via, dict):
                    continue
                vid = via.get("cve", "")
                if not vid:
                    url = via.get("url", "")
                    if "GHSA-" in url:
                        vid = "GHSA-" + url.split("GHSA-")[-1].split("/")[0]
                    elif via.get("source"):
                        vid = "NPM-" + str(via.get("source"))
                    else:
                        continue
                raw_score = float((via.get("cvss") or {}).get("score") or 0)
                cvss = raw_score if raw_score > 0 else None
                prev = vulns.get(vid)
                if prev is None or (cvss is not None and (prev["cvss"] is None or cvss > prev["cvss"])):
                    vulns[vid] = {"vuln_id":vid,"package":pkg_name,"version":info.get("range",""),"severity":sev,"cvss":cvss,"source":"npm"}
    print("[npm] " + str(len(vulns)) + " entries")
    return vulns

def merge(trivy, owasp, npm):
    merged = []
    for vid in sorted(set(trivy) | set(owasp) | set(npm)):
        sources, entry = [], None
        for d, label in [(trivy,"trivy"),(npm,"npm"),(owasp,"owasp")]:
            if vid in d:
                sources.append(label)
                if entry is None:
                    entry = d[vid].copy()
                else:
                    a, b = entry["cvss"], d[vid]["cvss"]
                    entry["cvss"] = max(a,b) if a is not None and b is not None else (a if a is not None else b)
        entry["source"] = "+".join(sources)
        entry["source_count"] = len(sources)
        merged.append(entry)
    merged.sort(key=lambda x: x["cvss"] if x["cvss"] is not None else -1, reverse=True)
    return merged

trivy  = parse_trivy(TRIVY_FILES)
owasp  = parse_owasp(OWASP_FILE)
npm    = parse_npm(NPM_FILES)
merged = merge(trivy, owasp, npm)
print("[merged] total=" + str(len(merged)))
with open(OUTPUT_FILE, "w", encoding="utf-8") as f:
    json.dump(merged, f, indent=2, ensure_ascii=False)
'''
                    sh "python3 ${WORKSPACE}/output/merge_vulns.py"
                }
            }
            post {
                failure { echo "CVE merge failed" }
            }
        }

        stage('6.7. Swagger Analysis') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    script {
                        if (!fileExists("${WORKSPACE}/src/swagger.yml")) {
                            echo "swagger.yml not found - skip"
                            return
                        }
                        sh "rm -f ${WORKSPACE}/output/swagger-analysis.json"

                        writeFile file: "${WORKSPACE}/output/parse_swagger.py", text: '''
import json, os, re, sys

try:
    import yaml
except ImportError:
    import subprocess
    try:
        subprocess.run(["apt-get","install","-y","-q","python3-yaml"], check=True, capture_output=True)
    except Exception:
        subprocess.run([sys.executable,"-m","pip","install","pyyaml","--break-system-packages","-q"], check=True)
    import yaml

WS           = os.environ["WORKSPACE"]
SWAGGER_FILE = WS + "/src/swagger.yml"
OUTPUT_FILE  = WS + "/output/swagger-analysis.json"

BIZ_CATEGORIES = [
    {"name":"payment",  "score":5,"keywords":["pay","payment","checkout","purchase","billing","charge","refund","transaction","pg","card","bank","stripe","invoice","order","orders"]},
    {"name":"auth",     "score":4,"keywords":["auth","login","logout","register","signup","password","token","oauth","session","credential","jwt","saml"]},
    {"name":"admin",    "score":4,"keywords":["admin","manager","dashboard","console","superuser","root","config","setting"]},
    {"name":"inventory","score":4,"keywords":["price","stock","inventory","quantity","discount","product-edit"]},
    {"name":"sandbox",  "score":4,"keywords":["vm","sandbox","eval","execute","template"]},
    {"name":"personal", "score":3,"keywords":["user","profile","personal","privacy","email","phone","address","delivery","shipping","ssn","kyc"]},
    {"name":"coupon",   "score":3,"keywords":["coupon","point","voucher","reward","promo"]},
    {"name":"security", "score":3,"keywords":["sanitize","xss","escape","helmet","validator","sql","inject"]},
    {"name":"product",  "score":1,"keywords":["product","item","catalog","search","list","category"]},
]
PUBLIC_METHODS = {"get","post","put","patch","delete"}

def get_biz_score(path_str):
    p = path_str.lower()
    for cat in BIZ_CATEGORIES:
        for kw in cat["keywords"]:
            if len(kw) >= 3 and kw in p:
                return cat["score"], cat["name"], kw
    return 0, "internal", ""

with open(SWAGGER_FILE, encoding="utf-8") as f:
    spec = yaml.safe_load(f)

base_path = (spec.get("basePath") or "").rstrip("/")
paths     = spec.get("paths") or {}
endpoints = []
summary   = {"total":0,"by_category":{},"by_method":{},"high_risk":[]}

for path, path_item in paths.items():
    if not isinstance(path_item, dict):
        continue
    for method, operation in path_item.items():
        if method.lower() not in PUBLIC_METHODS or not isinstance(operation, dict):
            continue
        full_path = base_path + path
        biz_score, biz_cat, matched_kw = get_biz_score(full_path)
        total_score = biz_score + 2
        entry = {
            "path":full_path,"method":method.upper(),
            "summary":operation.get("summary",""),"tags":operation.get("tags",[]),
            "biz_category":biz_cat,"biz_score":biz_score,"matched_kw":matched_kw,
            "is_public":True,"total_score":total_score,
            "params":[p.get("name","") for p in (operation.get("parameters") or [])],
            "auth_required":"security" in operation or "security" in spec
        }
        endpoints.append(entry)
        summary["total"] += 1
        summary["by_category"][biz_cat] = summary["by_category"].get(biz_cat,0)+1
        summary["by_method"][method.upper()] = summary["by_method"].get(method.upper(),0)+1
        if total_score >= 5:
            summary["high_risk"].append(full_path+" ["+method.upper()+"] score="+str(total_score))

SERVER_FILE = WS + "/src/server.ts"
if os.path.exists(SERVER_FILE):
    with open(SERVER_FILE, encoding="utf-8", errors="replace") as f:
        content = f.read()
    patterns = re.findall("app\\\\.(get|post|put|patch|delete)\\\\s*\\\\(\\\\s*[\'\\"]([^\'\\"]+)[\'\\"]", content)
    server_count = 0
    for method, path in patterns:
        if any(ep["path"]==path and ep["method"]==method.upper() for ep in endpoints):
            continue
        biz_score, biz_cat, matched_kw = get_biz_score(path)
        total_score = biz_score + 2
        endpoints.append({
            "path":path,"method":method.upper(),"summary":"","tags":[],
            "biz_category":biz_cat,"biz_score":biz_score,"matched_kw":matched_kw,
            "is_public":True,"total_score":total_score,"params":[],"auth_required":False,"source":"server.ts"
        })
        summary["total"] += 1
        summary["by_category"][biz_cat] = summary["by_category"].get(biz_cat,0)+1
        summary["by_method"][method.upper()] = summary["by_method"].get(method.upper(),0)+1
        if total_score >= 5:
            summary["high_risk"].append(path+" ["+method.upper()+"] score="+str(total_score)+" (server.ts)")
        server_count += 1
    print("[server.ts] " + str(server_count) + " routes added")

endpoints.sort(key=lambda x: x["total_score"], reverse=True)
with open(OUTPUT_FILE, "w", encoding="utf-8") as f:
    json.dump({"endpoints":endpoints,"summary":summary}, f, indent=2, ensure_ascii=False)
print("total endpoints=" + str(summary["total"]))
print("high_risk count=" + str(len(summary["high_risk"])))
'''
                        sh "python3 ${WORKSPACE}/output/parse_swagger.py"
                    }
                }
            }
        }

        stage('7. Business Context Analysis') {
            steps {
                dir("${WORKSPACE}/src") {
                    script {

                        def businessKeywords = [
                            payment  : [score: 5, keywords: ['pay', 'payment', 'checkout', 'purchase', 'billing',
                                                              'charge', 'refund', 'transaction', 'pg', 'card', 'bank',
                                                              'stripe', 'braintree', 'paypal', 'invoice', 'receipt',
                                                              'order', 'orders']],
                            auth     : [score: 4, keywords: ['auth', 'jwt', 'jsonwebtoken', 'token', 'oauth',
                                                              'passport', 'session', 'credential', 'login', 'saml',
                                                              'bcrypt', 'argon', 'scrypt', 'otplib', 'speakeasy',
                                                              'cookie', 'csrf', 'cors']],
                            admin    : [score: 4, keywords: ['admin', 'manager', 'dashboard', 'console',
                                                              'superuser', 'root', 'system', 'config', 'setting']],
                            inventory: [score: 4, keywords: ['price', 'stock', 'inventory', 'quantity',
                                                              'product-edit', 'update-price', 'discount']],
                            sandbox  : [score: 4, keywords: ['vm2', 'sandbox', 'serialize', 'deserializ',
                                                              'template', 'handlebars', 'pug', 'ejs', 'nunjucks',
                                                              'lodash', 'underscore', 'eval', 'expression',
                                                              'notevil', 'safe-eval', 'isolated-vm']],
                            personal : [score: 3, keywords: ['user', 'profile', 'personal', 'privacy', 'email',
                                                              'phone', 'address', 'delivery', 'shipping', 'ssn',
                                                              'kyc', 'user-info', 'pii', 'gdpr']],
                            coupon   : [score: 3, keywords: ['coupon', 'point', 'voucher', 'reward',
                                                              'promo', 'discount-code']],
                            security : [score: 3, keywords: ['sanitize', 'sanitize-html', 'xss', 'escape',
                                                              'helmet', 'validator', 'dompurify', 'marked',
                                                              'sql', 'inject']],
                            product  : [score: 1, keywords: ['product', 'item', 'catalog', 'search',
                                                              'list', 'category']]
                        ]

                        def categoryOrder = ['payment','auth','admin','inventory','sandbox',
                                             'personal','coupon','security','product']

                        def TRUST_WEIGHTS = [1.0, 1.0, 1.15, 1.30]
                        def MAX_RAW       = 96.0

                        def publicRoutes    = []
                        def semgrepFindings = []

                        if (fileExists("${WORKSPACE}/output/semgrep-result.json")) {
                            def semgrepJson = readJSON file: "${WORKSPACE}/output/semgrep-result.json"
                            semgrepJson.results?.each { finding ->
                                def msg  = finding.extra?.message?.toLowerCase() ?: ''
                                def rule = finding.check_id?.toLowerCase() ?: ''
                                def file = finding.path?.toLowerCase() ?: ''
                                semgrepFindings.add([file: finding.path, rule: rule, message: msg])
                                if (msg.contains('/api/') || msg.contains('/rest/') ||
                                    file.contains('route') || file.contains('router') ||
                                    rule.contains('route') || rule.contains('express')) {
                                    publicRoutes.add(msg)
                                }
                            }
                            echo "Semgrep routes: ${publicRoutes.size()}"
                        }

                        def swaggerEndpoints   = []
                        def swaggerPublicPaths = []
                        if (fileExists("${WORKSPACE}/output/swagger-analysis.json")) {
                            def swaggerJson = readJSON file: "${WORKSPACE}/output/swagger-analysis.json"
                            swaggerEndpoints = swaggerJson.endpoints ?: []
                            swaggerEndpoints.each { ep -> swaggerPublicPaths.add(ep.path?.toLowerCase() ?: '') }
                            echo "Swagger endpoints: ${swaggerEndpoints.size()}"
                        }

                        def vulnBusinessScores = []

                        def sourceFiles = fileExists("${WORKSPACE}/output/merged_vulns.json")
                            ? ["${WORKSPACE}/output/merged_vulns.json"]
                            : ["${WORKSPACE}/output/trivy-result.json",
                               "${WORKSPACE}/output/trivy-frontend-result.json"]

                        sourceFiles.each { filePath ->
                            if (!fileExists(filePath)) return
                            def vulnList = []

                            if (filePath.contains("merged_vulns")) {
                                vulnList = readJSON file: filePath
                            } else {
                                def trivyJson = readJSON file: filePath
                                trivyJson.Results?.each { result ->
                                    result.Vulnerabilities?.each { v ->
                                        def cvss = 0.0
                                        if (v.CVSS) {
                                            ['nvd','ghsa','redhat'].each { src ->
                                                if (v.CVSS[src] && cvss == 0.0) {
                                                    def v3 = v.CVSS[src]?.V3Score
                                                    def v2 = v.CVSS[src]?.V2Score
                                                    if (v3 != null) cvss = v3 as double
                                                    else if (v2 != null) cvss = v2 as double
                                                }
                                            }
                                        }
                                        if (cvss == 0.0) cvss = v.Severity == 'CRITICAL' ? 9.0 : 7.0
                                        vulnList.add([vuln_id:v.VulnerabilityID?:'', package:v.PkgName?:'',
                                            version:v.InstalledVersion?:'', severity:v.Severity?:'',
                                            cvss:cvss, source:'trivy', source_count:1])
                                    }
                                }
                            }

                            vulnList.each { vuln ->
                                def rawCvss   = vuln.cvss
                                def cvssScore = 0.0
                                try {
                                    if (rawCvss != null && !(rawCvss instanceof net.sf.json.JSONNull))
                                        cvssScore = rawCvss as double
                                } catch (Exception e) { cvssScore = 0.0 }
                                if (cvssScore == 0.0)
                                    cvssScore = (vuln.severity == 'CRITICAL') ? 9.0 : 7.0

                                def pkgName     = (vuln.package ?: '').toLowerCase()
                                def bizScore    = 0
                                def bizCategory = 'internal'
                                def matchedKw   = ''

                                for (int ci = 0; ci < categoryOrder.size(); ci++) {
                                    if (bizScore > 0) break
                                    def cat    = categoryOrder[ci]
                                    def config = businessKeywords[cat]
                                    for (int ki = 0; ki < config.keywords.size(); ki++) {
                                        def kw = config.keywords[ki]
                                        if (kw.length() >= 3 && pkgName.contains(kw)) {
                                            bizScore = config.score; bizCategory = cat; matchedKw = kw; break
                                        }
                                    }
                                }

                                if (publicRoutes.any { r -> r.contains(pkgName) } ||
                                    swaggerPublicPaths.any { pt -> pt.contains(pkgName) }) bizScore += 2

                                def swaggerBonus = 0
                                swaggerEndpoints.each { ep ->
                                    def epPath = (ep.path ?: '').toLowerCase()
                                    if (pkgName.length() >= 4 && epPath.contains(pkgName)) {
                                        def epBiz = (ep.biz_score != null) ? (ep.biz_score as int) : 0
                                        if (epBiz > swaggerBonus) swaggerBonus = epBiz
                                    }
                                }
                                if (swaggerBonus > bizScore) { bizScore = swaggerBonus; bizCategory = 'swagger-mapped' }

                                def reachability = 1.0
                                if (pkgName.length() >= 4 && semgrepFindings.any { f ->
                                    f.message?.contains(pkgName) || f.rule?.contains(pkgName) || f.file?.contains(pkgName)
                                }) reachability = 1.5

                                def srcCount    = (vuln.source_count != null) ? (vuln.source_count as int) : 1
                                def trustWeight = TRUST_WEIGHTS[Math.min(srcCount, TRUST_WEIGHTS.size()-1)] as double
                                def effectiveBiz = bizScore > 0 ? bizScore : 1
                                def rawScore     = cvssScore * reachability * effectiveBiz * trustWeight
                                def finalScore   = (rawScore / MAX_RAW) * 20.0
                                def gate = finalScore >= 14.0 ? 'Block' : finalScore >= 8.0 ? 'Warn' : 'Pass'

                                vulnBusinessScores.add([
                                    pkg:vuln.package?:'', version:vuln.version?:'', cve:vuln.vuln_id?:'',
                                    severity:vuln.severity?:'', cvss:cvssScore, bizCategory:bizCategory,
                                    bizScore:bizScore, matchedKw:matchedKw, reachability:reachability,
                                    trustWeight:trustWeight, sourceCount:srcCount, rawScore:rawScore,
                                    finalScore:finalScore, gate:gate, source:vuln.source?:''
                                ])
                            }
                        }

                        def n = vulnBusinessScores.size()
                        for (int i = 0; i < n-1; i++)
                            for (int j = 0; j < n-i-1; j++)
                                if ((vulnBusinessScores[j].finalScore as double) < (vulnBusinessScores[j+1].finalScore as double)) {
                                    def tmp = vulnBusinessScores[j]
                                    vulnBusinessScores[j] = vulnBusinessScores[j+1]
                                    vulnBusinessScores[j+1] = tmp
                                }

                        def top10 = vulnBusinessScores.take(10)
                        echo "====== TOP 10 ======"
                        top10.eachWithIndex { v, i ->
                            echo "${i+1}. ${v.cve} | ${v.pkg}@${v.version} | CVSS:${v.cvss} | ${v.bizCategory}(+${v.bizScore}) | final:${String.format('%.2f',v.finalScore as double)}/20 | ${v.gate}"
                        }

                        def blockCount = vulnBusinessScores.count { (it.finalScore as double) >= 14.0 }
                        def warnCount  = vulnBusinessScores.count { s -> def f = s.finalScore as double; f >= 8.0 && f < 14.0 }
                        def passCount  = vulnBusinessScores.count { (it.finalScore as double) < 8.0 }
                        echo "Block:${blockCount} Warn:${warnCount} Pass:${passCount}"

                        writeJSON file: "${WORKSPACE}/output/business-risk-result.json", json: vulnBusinessScores
                        echo "Business Context Analysis done"
                    }
                }
            }
        }

        stage('8. Risk Scoring & Gate') {
            steps {
                script {
                    def semgrepCount = 0, mergedHigh = 0, mergedCrit = 0
                    def maxFinal = 0.0, blockCount = 0, warnCount = 0

                    if (fileExists("${WORKSPACE}/output/semgrep-result.json")) {
                        def semJson = readJSON file: "${WORKSPACE}/output/semgrep-result.json"
                        semgrepCount = semJson.results?.size() ?: 0
                    }

                    if (fileExists("${WORKSPACE}/output/merged_vulns.json")) {
                        def mergedJson = readJSON file: "${WORKSPACE}/output/merged_vulns.json"
                        mergedJson.each { v ->
                            def sev = (v.severity ?: '').toUpperCase()
                            if (sev == 'HIGH') mergedHigh++
                            if (sev == 'CRITICAL') mergedCrit++
                        }
                    }

                    if (fileExists("${WORKSPACE}/output/business-risk-result.json")) {
                        def bizJson = readJSON file: "${WORKSPACE}/output/business-risk-result.json"
                        bizJson.each { v ->
                            def s = 0.0
                            try {
                                def raw = v.finalScore
                                if (raw != null && !(raw instanceof net.sf.json.JSONNull))
                                    s = raw as double
                            } catch (Exception e) { s = 0.0 }
                            if (s > maxFinal) maxFinal = s
                            if (s >= 14.0) blockCount++
                            else if (s >= 8.0) warnCount++
                        }
                    }

                    def swaggerHR = 0
                    if (fileExists("${WORKSPACE}/output/swagger-analysis.json")) {
                        def swaggerJson = readJSON file: "${WORKSPACE}/output/swagger-analysis.json"
                        swaggerHR = swaggerJson.summary?.high_risk?.size() ?: 0
                    }

                    def total = mergedHigh + mergedCrit
                    def critR = total > 0 ? (mergedCrit / total as double) : 0.0
                    def highR = total > 0 ? (mergedHigh  / total as double) : 0.0
                    def base  = (critR * 100) + (highR * 40) + (semgrepCount * 0.2)

                    echo "====== Risk Gate ======"
                    echo "CRITICAL:${mergedCrit} HIGH:${mergedHigh} Semgrep:${semgrepCount} SwaggerHighRisk:${swaggerHR}"
                    echo "baseScore:${String.format('%.1f',base)} maxBizScore:${String.format('%.2f',maxFinal)}/20"
                    echo "Block:${blockCount} Warn:${warnCount}"

                    if (blockCount > 0) {
                        currentBuild.result = 'FAILURE'
                        echo "BLOCKED - ${blockCount} vulns >= 14/20"
                    } else if (base >= 50.0) {
                        currentBuild.result = 'FAILURE'
                        echo "BLOCKED - baseScore ${String.format('%.1f',base)} >= 50"
                    } else if (base >= 30.0) {
                        currentBuild.result = 'UNSTABLE'
                        echo "WARN - baseScore ${String.format('%.1f',base)}"
                    } else {
                        echo "PASS - baseScore ${String.format('%.1f',base)}"
                    }
                }
            }
        }

        stage('9. Prometheus Push') {
            steps {
                script {
                    def bizJson     = fileExists("${WORKSPACE}/output/business-risk-result.json")
                        ? readJSON(file: "${WORKSPACE}/output/business-risk-result.json") : []
                    def mergedJson  = fileExists("${WORKSPACE}/output/merged_vulns.json")
                        ? readJSON(file: "${WORKSPACE}/output/merged_vulns.json") : []
                    def semgrepJson = fileExists("${WORKSPACE}/output/semgrep-result.json")
                        ? readJSON(file: "${WORKSPACE}/output/semgrep-result.json") : [results:[]]

                    def crit=0, high=0, block=0, warn=0, maxS=0.0

                    mergedJson.each { v ->
                        def sev = (v.severity?:'').toUpperCase()
                        if (sev=='CRITICAL') crit++
                        if (sev=='HIGH') high++
                    }
                    bizJson.each { v ->
                        def s = 0.0
                        try {
                            def raw = v.finalScore
                            if (raw != null && !(raw instanceof net.sf.json.JSONNull))
                                s = raw as double
                        } catch (Exception e) { s = 0.0 }
                        if (s > maxS) maxS = s
                        if (s >= 14.0) block++
                        else if (s >= 8.0) warn++
                    }

                    def sc   = semgrepJson.results?.size() ?: 0
                    def tot  = crit + high
                    def cR   = tot > 0 ? (crit/tot as double) : 0.0
                    def hR   = tot > 0 ? (high/tot as double) : 0.0
                    def base = (cR*100)+(hR*40)+(sc*0.2)

                    def metrics = """# HELP trivy_pipe_risk_score Risk Score
# TYPE trivy_pipe_risk_score gauge
trivy_pipe_risk_score ${String.format('%.2f',maxS)}
# HELP trivy_pipe_base_score Base Score
# TYPE trivy_pipe_base_score gauge
trivy_pipe_base_score ${String.format('%.1f',base)}
# HELP trivy_pipe_critical_count CRITICAL count
# TYPE trivy_pipe_critical_count gauge
trivy_pipe_critical_count ${crit}
# HELP trivy_pipe_high_count HIGH count
# TYPE trivy_pipe_high_count gauge
trivy_pipe_high_count ${high}
# HELP trivy_pipe_total_vulns total vulns
# TYPE trivy_pipe_total_vulns gauge
trivy_pipe_total_vulns ${mergedJson.size()}
# HELP trivy_pipe_block_count block count
# TYPE trivy_pipe_block_count gauge
trivy_pipe_block_count ${block}
# HELP trivy_pipe_warn_count warn count
# TYPE trivy_pipe_warn_count gauge
trivy_pipe_warn_count ${warn}
# HELP trivy_pipe_semgrep_count semgrep count
# TYPE trivy_pipe_semgrep_count gauge
trivy_pipe_semgrep_count ${sc}
# HELP trivy_pipe_build_status build status
# TYPE trivy_pipe_build_status gauge
trivy_pipe_build_status ${block > 0 || base >= 50.0 ? 0 : 1}
"""
                    writeFile file: "${WORKSPACE}/output/metrics.txt", text: metrics
                    sh """
                        curl -s -X POST \\
                            http://pushgateway:9091/metrics/job/trivy-pipe/instance/juice-shop \\
                            --data-binary @${WORKSPACE}/output/metrics.txt \\
                        && echo "Prometheus push OK" || echo "Prometheus push FAILED"
                    """
                }
            }
        }

        stage('10. Security Metrics Push') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    script {
                        sh """
                            if ! python3 -c "import prometheus_client" 2>/dev/null; then
                                apt-get update -qq 2>/dev/null || true
                                apt-get install -y -q python3-pip 2>/dev/null || true
                                python3 -m pip install prometheus_client --break-system-packages -q
                            fi
                            cp ${WORKSPACE}/security_metrics.py ${WORKSPACE}/output/security_metrics.py
                            WORKSPACE=${WORKSPACE} PUSHGATEWAY_URL=pushgateway:9091 \\
                                python3 ${WORKSPACE}/output/security_metrics.py
                        """
                    }
                }
            }
        }

    } // end stages

    post {
        always {
            archiveArtifacts artifacts: 'output/**', allowEmptyArchive: true
            script {
                if (fileExists('output/dependency-check-report.xml'))
                    dependencyCheckPublisher pattern: 'output/dependency-check-report.xml'
                else
                    echo "OWASP report missing - skip publisher"
            }
            echo "Result: ${currentBuild.currentResult}"
        }
        success { echo "Pipeline SUCCESS" }
        failure { echo "Pipeline FAILURE - check logs" }
        unstable { echo "Pipeline UNSTABLE - security review needed" }
    }
}
